ADSPOWER_API_KEY=
# Porta da Local API do AdsPower (Configurações > Local API no app). Só
# preencha se for diferente do padrão 50325.
ADSPOWER_API_PORT=

# conta padrão (usada por qualquer robô sem uma conta específica configurada abaixo)
BUILDFY_EMAIL=
BUILDFY_PASSWORD=

# contas específicas por robô (opcional) — preencha para o Robô A, B e/ou C
# usarem cada um sua própria conta Buildfy em vez de compartilhar a padrão acima

# ROBO A
BUILDFY_EMAIL_A=
BUILDFY_PASSWORD_A=

# ROBO B
BUILDFY_EMAIL_B=
BUILDFY_PASSWORD_B=

# ROBO C
BUILDFY_EMAIL_C=
BUILDFY_PASSWORD_C=

